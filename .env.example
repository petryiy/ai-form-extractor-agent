# DeepSeek OpenAI-compatible API.
DEEPSEEK_API_KEY=sk-your-deepseek-key
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-v4-flash

# Supabase persistence for production.
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Optional: protect /admin with HTTP Basic Auth.
# ADMIN_USERNAME=admin
# ADMIN_PASSWORD=change-me

# Optional: push completed forms to another system.
# REQUIREMENT_WEBHOOK_URL=https://example.com/webhook
# REQUIREMENT_WEBHOOK_SECRET=shared-secret
# REQUIREMENT_WEBHOOK_MODE=complete
